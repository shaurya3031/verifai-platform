{
  "manifest_version": 3,
  "name": "VerifAI Contextual Proof",
  "version": "1.0",
  "description": "Instantly verify news claims on any webpage using the VerifAI platform.",
  "permissions": ["contextMenus", "activeTab"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
